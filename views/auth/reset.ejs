<!doctype html>
<html>
<head><meta charset="utf-8"><title>Reset</title><meta name="csrf-token" content="<%= csrfToken %>"></head>
<body>
  <h3>Reset Password</h3>
  <form method="post" action="/reset/<%= token %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input name="password" type="password" required placeholder="New password">
    <input name="confirmPassword" type="password" required placeholder="Confirm password">
    <button type="submit">Reset</button>
  </form>
</body>
</html>
